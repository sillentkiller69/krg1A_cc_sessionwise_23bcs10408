#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    map<string,int> mp;

    for(int i = 0; i < n; i++){
        string s;
        cin >> s;
        mp[s]++;
    }

    string winner;
    int mx = 0;

    for(auto it : mp){
        if(it.second > mx){
            mx = it.second;
            winner = it.first;
        }
    }

    cout << winner << endl;
}
